#!/bin/bash
set -euo pipefail

# mac-mp4-screen-rec — Automatically convert macOS screen recordings and other video files
# https://github.com/arch1904/MacMp4ScreenRec

resolve_tool_path() {
    local tool_name="$1"
    local resolved_path

    resolved_path="$(command -v "$tool_name" 2>/dev/null || true)"
    if [ -n "$resolved_path" ]; then
        echo "$resolved_path"
        return 0
    fi

    for resolved_path in "/opt/homebrew/bin/${tool_name}" "/usr/local/bin/${tool_name}"; do
        if [ -x "$resolved_path" ]; then
            echo "$resolved_path"
            return 0
        fi
    done

    echo ""
}

VERSION="1.2.1"
CONFIG_DIR="${HOME}/.config/mac-mp4-screen-rec"
CONFIG_FILE="${CONFIG_DIR}/config"
RETENTION_DIR="${CONFIG_DIR}/retention"
PLIST_NAME="com.mac-mp4-screen-rec.agent"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_NAME}.plist"
FFMPEG="$(resolve_tool_path ffmpeg)"
FFPROBE="$(resolve_tool_path ffprobe)"
CLEANUP_INTERVAL_SECONDS=3600
_video_codec_map_inputs=()
_video_codec_map_outputs=()
_video_codec_map_count=0
_audio_codec_map_inputs=()
_audio_codec_map_outputs=()
_audio_codec_map_count=0

# ─── Helpers ──────────────────────────────────────────────

die() { echo "error: $1" >&2; exit 1; }
tildify() { echo "$1" | sed "s|^${HOME}|~|"; }

trim() {
    echo "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

lower() {
    echo "$1" | tr '[:upper:]' '[:lower:]'
}

normalize_extension() {
    local ext
    ext="$(trim "$1")"
    ext="${ext#.}"
    lower "$ext"
}

normalize_mode() {
    case "$(trim "$1")" in
        recordings-only) echo "recordings-only" ;;
        all-files|all-movs) echo "all-files" ;;
        *) echo "recordings-only" ;;
    esac
}

normalize_codec() {
    trim "$1"
}

normalize_codec_map_key() {
    lower "$(trim "$1")"
}

normalize_codec_map_entry() {
    local raw="$1"
    local input_codec output_codec

    case "$raw" in
        *=*)
            input_codec="$(normalize_codec_map_key "${raw%%=*}")"
            output_codec="$(normalize_codec "${raw#*=}")"
            ;;
        *)
            return 1
            ;;
    esac

    [ -n "$input_codec" ] || return 1
    [ -n "$output_codec" ] || return 1
    echo "${input_codec}=${output_codec}"
}

is_nonnegative_integer() {
    case "$1" in
        ''|*[!0-9]*) return 1 ;;
        *) return 0 ;;
    esac
}

join_by_comma() {
    local result=""
    local item
    for item in "$@"; do
        [ -n "$item" ] || continue
        if [ -n "$result" ]; then
            result="${result},${item}"
        else
            result="$item"
        fi
    done
    echo "$result"
}

normalize_extensions_csv() {
    local raw="$1"
    local ext
    local -a normalized=()
    local normalized_count=0

    while IFS= read -r ext; do
        ext="$(normalize_extension "$ext")"
        [ -n "$ext" ] || continue

        local seen=false
        local existing
        local idx
        for (( idx=0; idx<normalized_count; idx++ )); do
            existing="${normalized[$idx]}"
            if [ "$existing" = "$ext" ]; then
                seen=true
                break
            fi
        done

        if ! $seen; then
            normalized+=("$ext")
            normalized_count=$(( normalized_count + 1 ))
        fi
    done < <(printf '%s\n' "$raw" | tr ',[:space:]' '\n')

    [ "$normalized_count" -gt 0 ] || return 1
    join_by_comma "${normalized[@]}"
}

read_scalar_config() {
    local key="$1"
    local default_value="$2"
    ensure_config

    local value
    value=$(grep "^${key}:" "$CONFIG_FILE" | head -1 | sed "s/^${key}:[[:space:]]*//" || true)
    value="$(trim "${value:-}")"

    if [ -n "$value" ]; then
        echo "$value"
    else
        echo "$default_value"
    fi
}

ensure_config() {
    mkdir -p "$CONFIG_DIR" "$RETENTION_DIR"

    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" <<'EOF'
# mac-mp4-screen-rec config
# Watch paths (one per line, after "paths:" line)
paths:
~/Desktop

# Selection mode: "recordings-only" or "all-files"
mode: recordings-only

# Keep successfully converted originals for N days before deletion (0 = delete immediately)
keep_original_days: 0

# Comma-separated input file extensions to scan for
input_extensions: mov

# Output container extension
output_extension: mp4

# Default ffmpeg codec settings
video_codec: copy
audio_codec: copy

# Per-source codec overrides (format: input_codec=output_codec)
video_codec_map:

audio_codec_map:
EOF
    fi
}

read_paths() {
    ensure_config
    local in_paths=false
    local line=""

    while IFS= read -r line; do
        case "$line" in \#*) continue ;; esac
        [ -z "$line" ] && continue

        if [ "$line" = "paths:" ]; then
            in_paths=true
            continue
        fi

        case "$line" in *:\ *) in_paths=false; continue ;; esac
        case "$line" in *:) in_paths=false; continue ;; esac

        if $in_paths; then
            echo "${line/#\~/$HOME}"
        fi
    done < "$CONFIG_FILE"
}

read_codec_map_entries() {
    local section_name="$1"
    ensure_config
    local in_section=false
    local line=""

    while IFS= read -r line; do
        case "$line" in \#*) continue ;; esac

        if [ "$line" = "${section_name}:" ]; then
            in_section=true
            continue
        fi

        case "$line" in *:\ *)
            if $in_section; then
                in_section=false
            fi
            ;;
        esac
        case "$line" in *:)
            if [ "$line" != "${section_name}:" ] && $in_section; then
                in_section=false
            fi
            ;;
        esac

        if ! $in_section; then
            continue
        fi

        [ -n "$line" ] || continue

        local normalized_entry
        normalized_entry="$(normalize_codec_map_entry "$line" || true)"
        [ -n "$normalized_entry" ] || continue
        echo "$normalized_entry"
    done < "$CONFIG_FILE"
}

# Read paths into a bash 3.2-compatible array
_load_paths() {
    _paths=()
    while IFS= read -r _p; do
        _paths+=("$_p")
    done < <(read_paths)
}

read_mode() {
    normalize_mode "$(read_scalar_config "mode" "recordings-only")"
}

read_keep_original_days() {
    local days
    days="$(read_scalar_config "keep_original_days" "0")"
    if is_nonnegative_integer "$days"; then
        echo "$days"
    else
        echo "0"
    fi
}

read_input_extensions_csv() {
    local normalized
    normalized=$(normalize_extensions_csv "$(read_scalar_config "input_extensions" "mov")" || true)
    echo "${normalized:-mov}"
}

read_input_extensions() {
    local csv
    csv="$(read_input_extensions_csv)"
    printf '%s\n' "$csv" | tr ',' '\n'
}

_load_input_extensions() {
    _input_extensions=()
    while IFS= read -r _ext; do
        [ -n "$_ext" ] || continue
        _input_extensions+=("$_ext")
    done < <(read_input_extensions)
}

read_output_extension() {
    local ext
    ext="$(normalize_extension "$(read_scalar_config "output_extension" "mp4")")"
    echo "${ext:-mp4}"
}

read_video_codec() {
    local codec
    codec="$(normalize_codec "$(read_scalar_config "video_codec" "copy")")"
    echo "${codec:-copy}"
}

read_audio_codec() {
    local codec
    codec="$(normalize_codec "$(read_scalar_config "audio_codec" "copy")")"
    echo "${codec:-copy}"
}

read_video_codec_map_entries() {
    read_codec_map_entries "video_codec_map"
}

read_audio_codec_map_entries() {
    read_codec_map_entries "audio_codec_map"
}

read_video_codec_map_entries_blob() {
    read_video_codec_map_entries || true
}

read_audio_codec_map_entries_blob() {
    read_audio_codec_map_entries || true
}

_load_video_codec_map() {
    _video_codec_map_inputs=()
    _video_codec_map_outputs=()
    _video_codec_map_count=0
    while IFS= read -r _entry; do
        [ -n "$_entry" ] || continue
        _video_codec_map_inputs+=("${_entry%%=*}")
        _video_codec_map_outputs+=("${_entry#*=}")
        _video_codec_map_count=$(( _video_codec_map_count + 1 ))
    done < <(read_video_codec_map_entries)
}

_load_audio_codec_map() {
    _audio_codec_map_inputs=()
    _audio_codec_map_outputs=()
    _audio_codec_map_count=0
    while IFS= read -r _entry; do
        [ -n "$_entry" ] || continue
        _audio_codec_map_inputs+=("${_entry%%=*}")
        _audio_codec_map_outputs+=("${_entry#*=}")
        _audio_codec_map_count=$(( _audio_codec_map_count + 1 ))
    done < <(read_audio_codec_map_entries)
}

write_full_config() {
    local mode="$1"
    local keep_original_days="$2"
    local input_extensions_csv="$3"
    local output_extension="$4"
    local video_codec="$5"
    local audio_codec="$6"
    local video_codec_map_entries="$7"
    local audio_codec_map_entries="$8"
    shift 8
    local config_paths=("$@")
    local tmp
    tmp=$(mktemp)

    cat > "$tmp" <<EOF
# mac-mp4-screen-rec config
# Watch paths (one per line, after "paths:" line)
paths:
EOF

    local path
    for path in "${config_paths[@]}"; do
        [ -n "$path" ] || continue
        tildify "$path" >> "$tmp"
    done

    cat >> "$tmp" <<EOF

# Selection mode: "recordings-only" or "all-files"
mode: ${mode}

# Keep successfully converted originals for N days before deletion (0 = delete immediately)
keep_original_days: ${keep_original_days}

# Comma-separated input file extensions to scan for
input_extensions: ${input_extensions_csv}

# Output container extension
output_extension: ${output_extension}

# Default ffmpeg codec settings
video_codec: ${video_codec}
audio_codec: ${audio_codec}

# Per-source codec overrides (format: input_codec=output_codec)
video_codec_map:
EOF

    if [ -n "$video_codec_map_entries" ]; then
        while IFS= read -r entry; do
            [ -n "$entry" ] || continue
            printf '%s\n' "$entry" >> "$tmp"
        done <<< "$video_codec_map_entries"
    fi

    cat >> "$tmp" <<EOF

audio_codec_map:
EOF

    if [ -n "$audio_codec_map_entries" ]; then
        while IFS= read -r entry; do
            [ -n "$entry" ] || continue
            printf '%s\n' "$entry" >> "$tmp"
        done <<< "$audio_codec_map_entries"
    fi

    printf '\n' >> "$tmp"
    mv "$tmp" "$CONFIG_FILE"
}

write_paths() {
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "$@"
}

write_mode() {
    _load_paths
    write_full_config \
        "$(normalize_mode "$1")" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_keep_original_days() {
    local days="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$days" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_input_extensions_csv() {
    local extensions_csv="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$extensions_csv" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_output_extension() {
    local output_extension="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$output_extension" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_video_codec() {
    local video_codec="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$video_codec" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_audio_codec() {
    local audio_codec="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$audio_codec" \
        "$(read_video_codec_map_entries_blob)" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_video_codec_map_entries_blob() {
    local video_codec_map_entries="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$video_codec_map_entries" \
        "$(read_audio_codec_map_entries_blob)" \
        "${_paths[@]}"
}

write_audio_codec_map_entries_blob() {
    local audio_codec_map_entries="$1"
    _load_paths
    write_full_config \
        "$(read_mode)" \
        "$(read_keep_original_days)" \
        "$(read_input_extensions_csv)" \
        "$(read_output_extension)" \
        "$(read_video_codec)" \
        "$(read_audio_codec)" \
        "$(read_video_codec_map_entries_blob)" \
        "$audio_codec_map_entries" \
        "${_paths[@]}"
}

upsert_codec_map_entry_in_blob() {
    local existing_blob="$1"
    local new_entry="$2"
    local target_input="${new_entry%%=*}"
    local result=""
    local line=""

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        if [ "${line%%=*}" != "$target_input" ]; then
            if [ -n "$result" ]; then
                result="${result}"$'\n'"${line}"
            else
                result="${line}"
            fi
        fi
    done <<< "$existing_blob"

    if [ -n "$result" ]; then
        result="${result}"$'\n'"${new_entry}"
    else
        result="${new_entry}"
    fi

    printf '%s\n' "$result"
}

remove_codec_map_entry_from_blob() {
    local existing_blob="$1"
    local target_input="$2"
    local result=""
    local line=""

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        if [ "${line%%=*}" != "$target_input" ]; then
            if [ -n "$result" ]; then
                result="${result}"$'\n'"${line}"
            else
                result="${line}"
            fi
        fi
    done <<< "$existing_blob"

    printf '%s\n' "$result"
}

retention_marker_path() {
    local source_path="$1"
    echo "${RETENTION_DIR}/$(md5 -q -s "$source_path").state"
}

write_retention_marker() {
    local source_path="$1"
    local output_path="$2"
    local keep_original_days="$3"
    local delete_after_epoch
    delete_after_epoch=$(( $(date +%s) + (keep_original_days * 86400) ))

    cat > "$(retention_marker_path "$source_path")" <<EOF
source=${source_path}
output=${output_path}
delete_after=${delete_after_epoch}
EOF
}

clear_retention_marker() {
    local marker
    marker="$(retention_marker_path "$1")"
    [ -f "$marker" ] && rm -f "$marker"
}

service_is_loaded() {
    [ -f "$PLIST_PATH" ] && launchctl list "$PLIST_NAME" &>/dev/null
}

service_state() {
    if ! service_is_loaded; then
        echo "stopped"
        return 0
    fi

    launchctl print "gui/$(id -u)/${PLIST_NAME}" 2>/dev/null | sed -n 's/^[[:space:]]*state = //p' | head -1
}

service_last_exit_code() {
    if ! service_is_loaded; then
        echo ""
        return 0
    fi

    launchctl print "gui/$(id -u)/${PLIST_NAME}" 2>/dev/null | sed -n 's/^[[:space:]]*last exit code = //p' | head -1
}

read_marker_field() {
    local marker="$1"
    local field="$2"
    grep "^${field}=" "$marker" | head -1 | sed "s/^${field}=//" || true
}

cleanup_retained_originals() {
    local keep_original_days="$1"
    local now
    now=$(date +%s)
    local marker=""

    ensure_config

    for marker in "$RETENTION_DIR"/*.state; do
        [ -f "$marker" ] || continue

        local source_path output_path delete_after due_after
        source_path="$(read_marker_field "$marker" "source")"
        output_path="$(read_marker_field "$marker" "output")"
        delete_after="$(read_marker_field "$marker" "delete_after")"
        due_after="$delete_after"

        [ -n "$source_path" ] || { rm -f "$marker"; continue; }
        [ -f "$source_path" ] || { rm -f "$marker"; continue; }
        [ -n "$output_path" ] || continue
        [ -f "$output_path" ] || continue

        if [ "$keep_original_days" -eq 0 ]; then
            due_after=0
        fi

        if ! is_nonnegative_integer "${due_after:-}"; then
            due_after=0
        fi

        if [ "$now" -ge "$due_after" ]; then
            rm -f "$source_path"
            rm -f "$marker"
        fi
    done
}

# ─── Launchd plist generation ─────────────────────────────

generate_plist() {
    _load_paths

    if [ ${#_paths[@]} -eq 0 ]; then
        die "no watch paths configured. Add one with: mac-mp4-screen-rec add <path>"
    fi

    mkdir -p "$(dirname "$PLIST_PATH")"

    local watch_paths=""
    local path
    for path in "${_paths[@]}"; do
        watch_paths+="        <string>${path}</string>"$'\n'
    done

    cat > "$PLIST_PATH" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_NAME}</string>
    <key>ProgramArguments</key>
    <array>
        <string>$(command -v mac-mp4-screen-rec || echo "$0")</string>
        <string>convert</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>WatchPaths</key>
    <array>
${watch_paths}    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>${CLEANUP_INTERVAL_SECONDS}</integer>
    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
EOF
}

# ─── Convert logic ────────────────────────────────────────

file_extension() {
    local name="${1##*/}"
    case "$name" in
        *.*) normalize_extension "${name##*.}" ;;
        *) echo "" ;;
    esac
}

file_matches_input_extensions() {
    local source_path="$1"
    local current_extension
    current_extension="$(file_extension "$source_path")"
    [ -n "$current_extension" ] || return 1

    local wanted_extension
    for wanted_extension in "${_input_extensions[@]}"; do
        if [ "$wanted_extension" = "$current_extension" ]; then
            return 0
        fi
    done

    return 1
}

file_matches_mode() {
    local source_path="$1"
    local mode="$2"

    if [ "$mode" = "recordings-only" ]; then
        case "$(basename "$source_path")" in
            "Screen Recording"*) return 0 ;;
            *) return 1 ;;
        esac
    fi

    return 0
}

file_ready_for_conversion() {
    local source_path="$1"
    local now mod_time age
    now=$(date +%s)
    mod_time=$(stat -f %m "$source_path" 2>/dev/null || echo "")
    [ -n "$mod_time" ] || return 1
    age=$(( now - mod_time ))
    [ "$age" -ge 3 ]
}

output_supports_faststart() {
    case "$1" in
        mp4|m4v|m4a|mov) return 0 ;;
        *) return 1 ;;
    esac
}

detect_stream_codec() {
    local source_path="$1"
    local stream_selector="$2"
    [ -n "$FFPROBE" ] || return 0

    "$FFPROBE" \
        -v error \
        -select_streams "$stream_selector" \
        -show_entries stream=codec_name \
        -of default=nokey=1:noprint_wrappers=1 \
        "$source_path" 2>/dev/null | head -1
}

lookup_codec_override() {
    local source_codec="$1"
    shift
    local total="$#"
    [ -n "$source_codec" ] || return 1
    [ "$total" -gt 0 ] || return 1

    local half=$(( total / 2 ))
    local idx
    for (( idx=0; idx<half; idx++ )); do
        if [ "$source_codec" = "${@:$(( idx + 1 )):1}" ]; then
            echo "${@:$(( half + idx + 1 )):1}"
            return 0
        fi
    done

    return 1
}

resolve_video_codec() {
    local source_path="$1"
    local default_codec="$2"
    local source_codec override_codec
    source_codec="$(detect_stream_codec "$source_path" "v:0")"
    if [ "$_video_codec_map_count" -gt 0 ]; then
        override_codec="$(lookup_codec_override "$source_codec" "${_video_codec_map_inputs[@]}" "${_video_codec_map_outputs[@]}" || true)"
    else
        override_codec=""
    fi
    echo "${override_codec:-$default_codec}"
}

resolve_audio_codec() {
    local source_path="$1"
    local default_codec="$2"
    local source_codec override_codec
    source_codec="$(detect_stream_codec "$source_path" "a:0")"
    if [ "$_audio_codec_map_count" -gt 0 ]; then
        override_codec="$(lookup_codec_override "$source_codec" "${_audio_codec_map_inputs[@]}" "${_audio_codec_map_outputs[@]}" || true)"
    else
        override_codec=""
    fi
    echo "${override_codec:-$default_codec}"
}

convert_one_file() {
    local source_path="$1"
    local output_extension="$2"
    local video_codec="$3"
    local audio_codec="$4"
    local keep_original_days="$5"
    local source_extension output_path effective_video_codec effective_audio_codec

    source_extension="$(file_extension "$source_path")"
    [ -n "$source_extension" ] || return 0

    # This tool produces a sibling output file, so source and output extensions
    # must differ. Same-extension transcodes need a different naming strategy.
    if [ "$source_extension" = "$output_extension" ]; then
        return 0
    fi

    output_path="${source_path%.*}.${output_extension}"
    [ -f "$output_path" ] && return 0

    effective_video_codec="$(resolve_video_codec "$source_path" "$video_codec")"
    effective_audio_codec="$(resolve_audio_codec "$source_path" "$audio_codec")"

    local ffmpeg_args=(
        -nostdin
        -y
        -i "$source_path"
        -c:v "$effective_video_codec"
        -c:a "$effective_audio_codec"
    )

    if output_supports_faststart "$output_extension"; then
        ffmpeg_args+=(-movflags +faststart)
    fi

    ffmpeg_args+=("$output_path")

    if "$FFMPEG" "${ffmpeg_args[@]}" >/dev/null 2>&1; then
        if [ "$keep_original_days" -eq 0 ]; then
            rm -f "$source_path"
            clear_retention_marker "$source_path"
        else
            write_retention_marker "$source_path" "$output_path" "$keep_original_days"
        fi
    fi
}

do_convert() {
    [ -z "$FFMPEG" ] && die "ffmpeg not found. Install it: brew install ffmpeg"

    local mode keep_original_days output_extension video_codec audio_codec
    mode="$(read_mode)"
    keep_original_days="$(read_keep_original_days)"
    output_extension="$(read_output_extension)"
    video_codec="$(read_video_codec)"
    audio_codec="$(read_audio_codec)"

    cleanup_retained_originals "$keep_original_days"

    _load_paths
    _load_input_extensions
    _load_video_codec_map
    _load_audio_codec_map

    if { [ "$_video_codec_map_count" -gt 0 ] || [ "$_audio_codec_map_count" -gt 0 ]; } && [ -z "$FFPROBE" ]; then
        die "ffprobe not found. Install it with ffmpeg to use codec mapping rules"
    fi

    local dir=""
    for dir in "${_paths[@]}"; do
        [ -d "$dir" ] || continue

        while IFS= read -r -d '' file; do
            file_matches_input_extensions "$file" || continue
            file_matches_mode "$file" "$mode" || continue
            file_ready_for_conversion "$file" || continue

            convert_one_file "$file" "$output_extension" "$video_codec" "$audio_codec" "$keep_original_days"
        done < <(find "$dir" -maxdepth 1 -type f -print0 2>/dev/null)
    done
}

restart_service_if_running() {
    if service_is_loaded; then
        echo "restarting service to pick up changes..."
        cmd_stop
        cmd_start
    else
        echo "config updated."
    fi
}

print_config_usage() {
    cat <<EOF
usage: mac-mp4-screen-rec config [options]

Options:
  --all-files                    Convert all files matching input_extensions
  --all-movs                     Legacy alias for --all-files
  --only-recordings              Only convert Screen Recording* files
  --keep-original-days <days>    Keep originals for N days before deletion
  --input-extensions <list>      Comma-separated input extensions (example: mov,mkv,avi)
  --output-extension <ext>       Output container extension (default: mp4)
  --video-codec <codec>          Default ffmpeg video codec (default: copy)
  --audio-codec <codec>          Default ffmpeg audio codec (default: copy)
  --map-video-codec <in=out>     Override video codec for detected source codecs
  --map-audio-codec <in=out>     Override audio codec for detected source codecs
  --remove-video-codec-map <in>  Remove one video codec override
  --remove-audio-codec-map <in>  Remove one audio codec override
  --clear-video-codec-maps       Remove all video codec overrides
  --clear-audio-codec-maps       Remove all audio codec overrides
EOF
}

# ─── CLI commands ─────────────────────────────────────────

cmd_add() {
    local new_path="${1:?usage: mac-mp4-screen-rec add <path>}"
    new_path="$(cd "$new_path" 2>/dev/null && pwd)" || die "path does not exist: $1"

    _load_paths

    local path
    for path in "${_paths[@]}"; do
        if [ "$path" = "$new_path" ]; then
            echo "already watching: $(tildify "$new_path")"
            return 0
        fi
    done

    _paths+=("$new_path")
    write_paths "${_paths[@]}"
    echo "added: $(tildify "$new_path")"
    restart_service_if_running
}

cmd_remove() {
    local rm_path="${1:?usage: mac-mp4-screen-rec remove <path>}"
    rm_path="$(cd "$rm_path" 2>/dev/null && pwd)" || rm_path="${rm_path/#\~/$HOME}"

    _load_paths
    local -a new_paths=()
    local found=false
    local path

    for path in "${_paths[@]}"; do
        if [ "$path" = "$rm_path" ]; then
            found=true
        else
            new_paths+=("$path")
        fi
    done

    if ! $found; then
        die "not watching: $(tildify "$rm_path")"
    fi

    if [ ${#new_paths[@]} -eq 0 ]; then
        write_paths ""
    else
        write_paths "${new_paths[@]}"
    fi

    echo "removed: $(tildify "$rm_path")"
    restart_service_if_running
}

cmd_list() {
    ensure_config
    echo "mac-mp4-screen-rec v${VERSION}"
    echo ""
    echo "Watch paths:"
    _load_paths
    if [ ${#_paths[@]} -eq 0 ]; then
        echo "  (none)"
    else
        local path
        for path in "${_paths[@]}"; do
            echo "  $(tildify "$path")"
        done
    fi
    echo ""
    echo "Selection mode: $(read_mode)"
    echo "Keep originals: $(read_keep_original_days) day(s)"
    echo "Input extensions: $(read_input_extensions_csv)"
    echo "Output extension: .$(read_output_extension)"
    echo "Default video codec: $(read_video_codec)"
    echo "Default audio codec: $(read_audio_codec)"
    echo "Video codec overrides:"
    local entry
    local has_video_codec_overrides=false
    while IFS= read -r entry; do
        [ -n "$entry" ] || continue
        has_video_codec_overrides=true
        echo "  ${entry}"
    done < <(read_video_codec_map_entries)
    if ! $has_video_codec_overrides; then
        echo "  (none)"
    fi
    echo "Audio codec overrides:"
    local has_audio_codec_overrides=false
    while IFS= read -r entry; do
        [ -n "$entry" ] || continue
        has_audio_codec_overrides=true
        echo "  ${entry}"
    done < <(read_audio_codec_map_entries)
    if ! $has_audio_codec_overrides; then
        echo "  (none)"
    fi
}

cmd_config() {
    [ $# -gt 0 ] || {
        cmd_list
        return 0
    }

    local changed=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --all-files|--all-movs)
                write_mode "all-files"
                echo "selection mode set to: all-files"
                changed=true
                shift
                ;;
            --only-recordings)
                write_mode "recordings-only"
                echo "selection mode set to: recordings-only"
                changed=true
                shift
                ;;
            --keep-original-days)
                [ $# -ge 2 ] || die "missing value for --keep-original-days"
                is_nonnegative_integer "$2" || die "--keep-original-days must be a non-negative integer"
                write_keep_original_days "$2"
                echo "keep_original_days set to: $2"
                changed=true
                shift 2
                ;;
            --input-extensions)
                [ $# -ge 2 ] || die "missing value for --input-extensions"
                local normalized_input_extensions
                normalized_input_extensions=$(normalize_extensions_csv "$2") || die "--input-extensions must include at least one extension"
                write_input_extensions_csv "$normalized_input_extensions"
                echo "input_extensions set to: $normalized_input_extensions"
                changed=true
                shift 2
                ;;
            --output-extension)
                [ $# -ge 2 ] || die "missing value for --output-extension"
                local normalized_output_extension
                normalized_output_extension="$(normalize_extension "$2")"
                [ -n "$normalized_output_extension" ] || die "--output-extension must not be empty"
                write_output_extension "$normalized_output_extension"
                echo "output_extension set to: $normalized_output_extension"
                changed=true
                shift 2
                ;;
            --video-codec)
                [ $# -ge 2 ] || die "missing value for --video-codec"
                local normalized_video_codec
                normalized_video_codec="$(normalize_codec "$2")"
                [ -n "$normalized_video_codec" ] || die "--video-codec must not be empty"
                write_video_codec "$normalized_video_codec"
                echo "default video codec set to: $normalized_video_codec"
                changed=true
                shift 2
                ;;
            --audio-codec)
                [ $# -ge 2 ] || die "missing value for --audio-codec"
                local normalized_audio_codec
                normalized_audio_codec="$(normalize_codec "$2")"
                [ -n "$normalized_audio_codec" ] || die "--audio-codec must not be empty"
                write_audio_codec "$normalized_audio_codec"
                echo "default audio codec set to: $normalized_audio_codec"
                changed=true
                shift 2
                ;;
            --map-video-codec)
                [ $# -ge 2 ] || die "missing value for --map-video-codec"
                local normalized_video_codec_map_entry
                normalized_video_codec_map_entry="$(normalize_codec_map_entry "$2")" || die "--map-video-codec must look like input_codec=output_codec"
                write_video_codec_map_entries_blob "$(upsert_codec_map_entry_in_blob "$(read_video_codec_map_entries_blob)" "$normalized_video_codec_map_entry")"
                echo "video codec override set: $normalized_video_codec_map_entry"
                changed=true
                shift 2
                ;;
            --map-audio-codec)
                [ $# -ge 2 ] || die "missing value for --map-audio-codec"
                local normalized_audio_codec_map_entry
                normalized_audio_codec_map_entry="$(normalize_codec_map_entry "$2")" || die "--map-audio-codec must look like input_codec=output_codec"
                write_audio_codec_map_entries_blob "$(upsert_codec_map_entry_in_blob "$(read_audio_codec_map_entries_blob)" "$normalized_audio_codec_map_entry")"
                echo "audio codec override set: $normalized_audio_codec_map_entry"
                changed=true
                shift 2
                ;;
            --remove-video-codec-map)
                [ $# -ge 2 ] || die "missing value for --remove-video-codec-map"
                local removed_video_codec_input
                removed_video_codec_input="$(normalize_codec_map_key "$2")"
                [ -n "$removed_video_codec_input" ] || die "--remove-video-codec-map must not be empty"
                write_video_codec_map_entries_blob "$(remove_codec_map_entry_from_blob "$(read_video_codec_map_entries_blob)" "$removed_video_codec_input")"
                echo "video codec override removed: $removed_video_codec_input"
                changed=true
                shift 2
                ;;
            --remove-audio-codec-map)
                [ $# -ge 2 ] || die "missing value for --remove-audio-codec-map"
                local removed_audio_codec_input
                removed_audio_codec_input="$(normalize_codec_map_key "$2")"
                [ -n "$removed_audio_codec_input" ] || die "--remove-audio-codec-map must not be empty"
                write_audio_codec_map_entries_blob "$(remove_codec_map_entry_from_blob "$(read_audio_codec_map_entries_blob)" "$removed_audio_codec_input")"
                echo "audio codec override removed: $removed_audio_codec_input"
                changed=true
                shift 2
                ;;
            --clear-video-codec-maps)
                write_video_codec_map_entries_blob ""
                echo "video codec overrides cleared"
                changed=true
                shift
                ;;
            --clear-audio-codec-maps)
                write_audio_codec_map_entries_blob ""
                echo "audio codec overrides cleared"
                changed=true
                shift
                ;;
            --help|-h)
                print_config_usage
                return 0
                ;;
            *)
                die "unknown config option: $1"
                ;;
        esac
    done

    if $changed; then
        restart_service_if_running
    fi
}

cmd_start() {
    [ -z "$FFMPEG" ] && die "ffmpeg not found. Install it: brew install ffmpeg"
    generate_plist
    launchctl load "$PLIST_PATH" 2>/dev/null || true

    if service_is_loaded; then
        echo "service started."
    else
        die "failed to start service"
    fi
}

cmd_stop() {
    if service_is_loaded; then
        launchctl unload "$PLIST_PATH" 2>/dev/null || true
        echo "service stopped."
    else
        echo "service is not running."
    fi
}

cmd_status() {
    local state exit_code
    state="$(service_state)"
    exit_code="$(service_last_exit_code)"

    if [ "$state" = "stopped" ]; then
        echo "service: stopped"
    elif [ "$state" = "not running" ]; then
        if [ -n "$exit_code" ]; then
            echo "service: loaded (idle, last exit ${exit_code})"
        else
            echo "service: loaded (idle)"
        fi
    elif [ -n "$exit_code" ]; then
        echo "service: ${state} (last exit ${exit_code})"
    else
        echo "service: ${state}"
    fi
    echo ""
    cmd_list
}

cmd_help() {
    cat <<EOF
mac-mp4-screen-rec v${VERSION}
Automatically convert macOS screen recordings and other video files with ffmpeg.

Usage:
  mac-mp4-screen-rec <command> [options]

Commands:
  add <path>                     Add a directory to watch
  remove <path>                  Remove a watched directory
  list                           Show current configuration
  config [options]               Update conversion settings
  start                          Start the background service
  stop                           Stop the background service
  status                         Show service status and config
  convert                        Run one conversion/cleanup pass immediately
  help                           Show this help message
  version                        Show version

Config options:
  --all-files                    Convert all files matching input_extensions
  --all-movs                     Legacy alias for --all-files
  --only-recordings              Only convert Screen Recording* files (default)
  --keep-original-days <days>    Keep originals for N days before deletion
  --input-extensions <list>      Comma-separated input extensions (default: mov)
  --output-extension <ext>       Output container extension (default: mp4)
  --video-codec <codec>          Default ffmpeg video codec (default: copy)
  --audio-codec <codec>          Default ffmpeg audio codec (default: copy)
  --map-video-codec <in=out>     Override video codec by detected source codec
  --map-audio-codec <in=out>     Override audio codec by detected source codec
  --remove-video-codec-map <in>  Remove one video codec override
  --remove-audio-codec-map <in>  Remove one audio codec override
  --clear-video-codec-maps       Remove all video codec overrides
  --clear-audio-codec-maps       Remove all audio codec overrides

Examples:
  mac-mp4-screen-rec add ~/Desktop
  mac-mp4-screen-rec config --all-files --input-extensions mov,mkv --output-extension mp4
  mac-mp4-screen-rec config --video-codec libx264 --audio-codec aac
  mac-mp4-screen-rec config --map-video-codec hevc=libx264
  mac-mp4-screen-rec config --map-audio-codec pcm_s16le=aac
  mac-mp4-screen-rec config --keep-original-days 7
  mac-mp4-screen-rec convert
EOF
}

# ─── Main ─────────────────────────────────────────────────

case "${1:-help}" in
    add)        shift; cmd_add "$@" ;;
    remove)     shift; cmd_remove "$@" ;;
    list)       cmd_list ;;
    config)     shift; cmd_config "$@" ;;
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    status)     cmd_status ;;
    convert)    do_convert ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "mac-mp4-screen-rec v${VERSION}" ;;
    *)          echo "unknown command: $1"; cmd_help; exit 1 ;;
esac
